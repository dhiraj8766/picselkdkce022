#!/bin/sh
set -e
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
  MAVEN_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2- | tr -d '\r')
fi
MAVEN_URL="${MAVEN_URL:-https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip}"

if [ ! -d "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven" ]; then
  echo "Downloading Maven..."
  mkdir -p "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven"
  if command -v curl > /dev/null; then
    curl -fsSL "$MAVEN_URL" -o /tmp/maven.zip
  elif command -v wget > /dev/null; then
    wget -q "$MAVEN_URL" -O /tmp/maven.zip
  fi
  unzip -qo /tmp/maven.zip -d "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven"
  rm -f /tmp/maven.zip
fi

MAVEN_HOME=$(find "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven" -maxdepth 1 -type d -name "apache-maven-*" | head -1)
exec "$MAVEN_HOME/bin/mvn" "$@"
